<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Mini Whatsapp</title>
</head>
<body>
    <h3>All Chats!</h3>
    
</body>
</html>

<% for(let chat of chats){ %>
    <div class="chat">
    <p>From : <%= chat.from %> </p>
    <div class="msg">
        <p><%= chat.msg %></p>
    </div>
    <p><%= chat.received %></p>
    </div>
    <% } %>